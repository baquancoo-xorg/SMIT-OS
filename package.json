{
  "name": "smit-os",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore './logs/**' --ignore './dist/**' --ignore './node_modules/**' --ignore './.claude/**' server.ts",
    "tunnel:status": "sudo launchctl list | grep cloudflare || echo 'cloudflared daemon not running'",
    "tunnel:restart": "sudo launchctl kickstart -k system/com.cloudflare.cloudflared",
    "tunnel:logs": "log stream --predicate 'subsystem == \"com.cloudflare.cloudflared\"' --style compact",
    "tunnel:stop": "sudo launchctl bootout system/com.cloudflare.cloudflared",
    "tunnel:start": "sudo launchctl bootstrap system /Library/LaunchDaemons/com.cloudflare.cloudflared.plist",
    "daemon:install": "launchctl bootout gui/$(id -u)/com.smitos.dev 2>/dev/null; cp scripts/com.smitos.dev.plist ~/Library/LaunchAgents/com.smitos.dev.plist && launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.smitos.dev.plist && echo 'Daemon installed and loaded.'",
    "daemon:uninstall": "launchctl bootout gui/$(id -u)/com.smitos.dev 2>/dev/null; rm -f ~/Library/LaunchAgents/com.smitos.dev.plist && echo 'Daemon uninstalled.'",
    "daemon:status": "launchctl print gui/$(id -u)/com.smitos.dev 2>/dev/null | grep -E 'state|pid|last exit code' || echo 'daemon not loaded'",
    "daemon:logs": "tail -f ~/Library/Logs/smit-os-dev.out.log ~/Library/Logs/smit-os-dev.err.log",
    "daemon:restart": "launchctl kickstart -k gui/$(id -u)/com.smitos.dev && echo 'Daemon restarted.'",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "tsx --env-file=.env --test \"src/**/*.{test,spec}.{ts,tsx}\" \"server/**/*.{test,spec}.{ts,tsx}\" \"scripts/**/*.{test,spec}.{ts,tsx}\"",
    "test:ci": "sh -c 'find src server scripts -type f \\( -name \"*.test.ts\" -o -name \"*.test.tsx\" -o -name \"*.spec.ts\" -o -name \"*.spec.tsx\" \\) | grep -q . || { echo \"No test files found\"; exit 1; }; tsx --test \"src/**/*.{test,spec}.{ts,tsx}\" \"server/**/*.{test,spec}.{ts,tsx}\" \"scripts/**/*.{test,spec}.{ts,tsx}\"'",
    "start": "tsx server.ts",
    "postinstall": "prisma generate",
    "prisma:gen": "prisma generate && prisma generate --schema=prisma/crm-schema.prisma",
    "prisma:pull:crm": "prisma db pull --schema=prisma/crm-schema.prisma",
    "db:setup": "tsx scripts/setup-db.ts",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed-exchange": "tsx scripts/seed-exchange-rate.ts",
    "db:seed-okrs": "tsx scripts/seed-okrs.ts",
    "db:seed:lead-status": "tsx prisma/seeds/lead-status-mapping.seed.ts",
    "db:seed:acquisition": "tsx prisma/seeds/acquisition.seed.ts",
    "backfill:leads": "tsx scripts/backfill-crm-leads.ts",
    "backfill:lead-source": "tsx scripts/backfill-lead-source.ts",
    "monitor:ui-regression": "tsx --env-file=.env scripts/posthog-ui-regression-monitor.ts"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@prisma/client": "^6.2.1",
    "@tanstack/react-query": "^5.99.0",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.12.42",
    "lru-cache": "^11.3.6",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cron": "^4.2.1",
    "otpauth": "^9.5.0",
    "pino": "^10.3.1",
    "prisma": "^6.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(uuid())
  fullName   String
  department String
  role       String
  avatar     String?
  objectives Objective[]
  workItems  WorkItem[]
}

model Objective {
  id                 String      @id @default(uuid())
  level              String      // L1, L2
  title              String
  ownerId            String
  department         String?
  parentObjectiveId  String?
  quarter            String
  progressPercentage Int         @default(0)
  
  owner              User        @relation(fields: [ownerId], references: [id])
  parentObjective    Objective?  @relation("ObjectiveHierarchy", fields: [parentObjectiveId], references: [id])
  childObjectives    Objective[] @relation("ObjectiveHierarchy")
  keyResults         KeyResult[]
}

model KeyResult {
  id            String         @id @default(uuid())
  title         String
  targetValue   Float
  currentValue  Float          @default(0)
  unit          String
  dueDate       DateTime?
  objectiveId   String
  
  objective     Objective      @relation(fields: [objectiveId], references: [id])
  subKeyResults SubKeyResult[]
}

model SubKeyResult {
  id           String    @id @default(uuid())
  title        String
  targetValue  Float
  currentValue Float     @default(0)
  unit         String
  dueDate      DateTime?
  keyResultId  String
  
  keyResult    KeyResult @relation(fields: [keyResultId], references: [id])
}

model WorkItem {
  id           String    @id @default(uuid())
  type         String    // Epic, UserStory, TechTask, Campaign, MktTask, MediaTask, SaleTask
  title        String
  description  String?
  priority     String
  estimatedTime String?
  status       String
  sprintId     String?
  storyPoint   Int?
  dueDate      DateTime?
  customerName String?
  dealValue    Float?
  assigneeId   String
  linkedKrId   String?
  
  assignee     User      @relation(fields: [assigneeId], references: [id])
  subtasks     Subtask[]
}

model Subtask {
  id         String   @id @default(uuid())
  title      String
  completed  Boolean  @default(false)
  workItemId String
  
  workItem   WorkItem @relation(fields: [workItemId], references: [id])
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  fullName   String
  username   String   @unique
  password   String
  department String
  role       String   // Admin, Leader, Member
  scope      String?  // Vị trí công việc (e.g., "Backend Developer")
  avatar     String
  isAdmin    Boolean  @default(false)
  objectives Objective[]
  workItems  WorkItem[]
  reports    WeeklyReport[]
}

model Sprint {
  id        String     @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  workItems WorkItem[]
}

model Objective {
  id                 String      @id @default(uuid())
  title              String
  department         String
  progressPercentage Float       @default(0)
  ownerId            String?
  owner              User?       @relation(fields: [ownerId], references: [id])
  parentId           String?     // For L2 objectives, references parent L1 objective
  parent             Objective?  @relation("ObjectiveHierarchy", fields: [parentId], references: [id])
  children           Objective[] @relation("ObjectiveHierarchy")
  keyResults         KeyResult[]
}

model KeyResult {
  id                 String    @id @default(uuid())
  title              String
  progressPercentage Float     @default(0)
  currentValue       Float     @default(0)
  targetValue        Float     @default(100)
  unit               String    @default("%")
  objectiveId        String
  objective          Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
}

model WorkItem {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("Todo")
  priority    String   @default("Medium")
  type        String   @default("Task")
  assigneeId  String?
  assignee    User?    @relation(fields: [assigneeId], references: [id])
  sprintId    String?
  sprint      Sprint?  @relation(fields: [sprintId], references: [id])
  linkedKrId  String?  // Links work item to a Key Result
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Specific fields for different views
  storyPoints Int?     // For Tech
}

model WeeklyReport {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  weekEnding DateTime
  progress   String   // JSON string
  plans      String   // JSON string
  blockers   String   // JSON string
  score      Int      @default(0)
  createdAt  DateTime @default(now())
}

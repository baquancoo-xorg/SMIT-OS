generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/crm-client"
}

datasource db {
  provider = "postgresql"
  url      = env("CRM_DATABASE_URL")
}

model CrmSubscriber {
  id                   BigInt    @id
  gate_utm_key         String?
  email                String?
  phone                String?
  fullName             String?   @map("full_name")
  company_name         String?
  companyRole          String?   @map("company_role")
  company_model        String?
  company_industry     String?
  source               String?
  adBudgetMonth        String?   @map("ad_budget_month")
  adAccountQty         String?   @map("ad_account_quantity")
  ref_code             String?
  gate_interest        Json?
  company_subtype      String?
  verify_info          String?
  preliminary_needs    String?
  bant_budget          String?
  bant_authority       String?
  bant_need            String?
  bant_timeline        String?
  potential_assessment String?
  priority_level       String?
  rate_score           Int?
  merge_status         String?
  mql_date             DateTime? @db.Timestamptz(6)
  status               String?
  duplicate_id         String?
  is_archived          Boolean?
  employee_id_modified Int?
  json_ldp             Json?
  createdAt            DateTime  @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  PEERDB_IS_DELETED    Boolean?  @default(false) @map("_PEERDB_IS_DELETED")
  PEERDB_SYNCED_AT     DateTime? @default(now()) @map("_PEERDB_SYNCED_AT") @db.Timestamp(6)

  @@map("crm_subscribers")
}

model CrmBusiness {
  id                        Int       @id
  bid                       String?
  name                      String?
  timezone_id               Decimal?  @db.Decimal(8, 2)
  created_by                Int?
  business_type             String?
  business_status           String?
  isTrial                   Boolean?  @map("is_trial")
  duration_trial_day        Int?
  plan_package_name         String?
  plan_package_amount       Decimal?  @db.Decimal(16, 2)
  plan_limit_spend_month    Decimal?  @db.Decimal(16, 2)
  plan_limit_adaccount      Int?
  plan_limit_employee       Int?
  plan_expired_at           DateTime? @db.Timestamptz(6)
  plan_active_at            DateTime? @db.Timestamptz(6)
  plan_duration             String?
  plan_is_enterprise        Boolean?
  plan_is_limited           Boolean?
  business_industry         String?
  business_subtype          String?
  business_health           String?
  last_checkin_date         DateTime? @db.Timestamptz(6)
  next_checkin_date         DateTime? @db.Timestamptz(6)
  last_business_review_date DateTime? @db.Timestamptz(6)
  contract_start_date       DateTime? @db.Timestamptz(6)
  contract_end_date         DateTime? @db.Timestamptz(6)
  renewal_status            String?
  churn_reason              String?
  churn_reason_note         String?
  createdAt                 DateTime  @map("created_at") @db.Timestamptz(6)
  updated_at                DateTime  @db.Timestamptz(6)
  PEERDB_IS_DELETED         Boolean?  @default(false) @map("_PEERDB_IS_DELETED")
  PEERDB_SYNCED_AT          DateTime? @default(now()) @map("_PEERDB_SYNCED_AT") @db.Timestamp(6)

  @@map("crm_businesses")
}

model CrmOpportunity {
  id                        BigInt    @id
  created_by                Int?
  contact_id                Int?
  subscriber_id             Int?
  opportunity_name          String?
  opportunity_type          String?
  status                    String?
  primary_contact           String?
  package_type              String?
  limit_spend_month         Decimal?  @db.Decimal(16, 2)
  limit_adaccount           Int?
  limit_employee            Int?
  payment_method            String?
  opportunity_value         Decimal?  @db.Decimal(16, 2)
  upcoming_topic            String?
  meddic_metric             String?
  meddic_economic_buyer     String?
  meddic_decision_criteria  String?
  meddic_decision_process   String?
  meddic_identify_pain      String?
  meddic_champion           String?
  win_factor_or_loss_reason String?
  detailed_win_loss_notes   String?
  next_plan_time            DateTime? @db.Timestamptz(6)
  expected_close_time       DateTime? @db.Timestamptz(6)
  opportunity_end_time      DateTime? @db.Timestamptz(6)
  employee_id_modified      Int?
  createdAt                 DateTime  @map("created_at") @db.Timestamptz(6)
  updated_at                DateTime  @db.Timestamptz(6)
  PEERDB_IS_DELETED         Boolean?  @default(false) @map("_PEERDB_IS_DELETED")
  PEERDB_SYNCED_AT          DateTime? @default(now()) @map("_PEERDB_SYNCED_AT") @db.Timestamp(6)

  @@map("crm_opportunities")
}

model BusinessTransaction {
  id                        Int       @id
  business_id               Int?
  status                    String?
  user_confirm              Int?
  total_amount              Decimal?  @db.Decimal(16, 2)
  total_discount            Decimal?  @db.Decimal(16, 2)
  amount_after_discount     Decimal?  @db.Decimal(16, 2)
  userPaid                  Decimal?  @map("user_paid") @db.Decimal(16, 2)
  export_invoice            Boolean?
  exported_invoice          Boolean?
  is_created_bus            Boolean?
  isTrial                   Boolean?  @map("is_trial")
  duration_trial            Int?
  user_account_holder       String?
  bank_content              String?
  company_name              String?
  company_address           String?
  company_legal_name        String?
  company_invoice_number    String?
  company_recipient_name    String?
  company_recipient_address String?
  company_recipient_phone   String?
  company_recipient_email   String?
  limit_spend_month         Decimal?  @db.Decimal(16, 2)
  limit_adaccount           Int?
  limit_employee            Int?
  duration_month            Int?
  staff_id                  Int?
  actived_at                DateTime? @db.Timestamptz(6)
  expired_at                DateTime? @db.Timestamptz(6)
  createdAt                 DateTime  @map("created_at") @db.Timestamptz(6)
  updated_at                DateTime  @db.Timestamptz(6)
  package_name              String?
  type                      String?
  package_amount            Float?
  discount_id               Int?
  business_type             Int?
  is_enterprise             Boolean?
  amount_remaining          Float?
  payment_method            String?
  rating                    Json?
  PEERDB_IS_DELETED         Boolean?  @default(false) @map("_PEERDB_IS_DELETED")
  PEERDB_SYNCED_AT          DateTime? @default(now()) @map("_PEERDB_SYNCED_AT") @db.Timestamp(6)

  @@map("business_transaction")
}


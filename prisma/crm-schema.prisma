/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model product_events {
  id                BigInt   @id @default(autoincrement())
  subscriber_id     Int
  business_id       Int?
  event_type        String   @db.VarChar(100)
  event_category    String   @db.VarChar(50)
  event_data        Json?    @default("{}")
  session_id        String?  @db.VarChar(50)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  PEERDB_IS_DELETED Boolean? @default(false) @map("_PEERDB_IS_DELETED")

  @@index([event_category, created_at(sort: Desc)], map: "idx_pe_category_created")
  @@index([event_data], map: "idx_pe_data_gin", type: Gin)
  @@index([subscriber_id, created_at(sort: Desc)], map: "idx_pe_subscriber_created")
  @@index([event_type, created_at(sort: Desc)], map: "idx_pe_type_created")
}

model smit_ae_name_mapping {
  id                Int       @id @default(autoincrement())
  official_name     String
